<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Survey Form</title>
  </head>
<body>

  <h1 id="title">Survey Form</h1>

  <p id="description">
    Please fill out this survey form with your details.
  </p>

  <form id="survey-form">

    <!-- Name Input -->
    <label id="name-label" for="name">Name:</label>
    <input 
      type="text" 
      id="name" 
      placeholder="Islamiyyah" 
      required
    >

    <br><br>

    <!-- Email Input -->
    <label id="email-label"for="email">Email:</label>
    <input 
      type="email" 
      id="email" 
      placeholder="islamiyyahisiaq9@gmail.com" 
      required
    >
    
    <!-- Number input-->
      <label id="number-label" for="number">Number</label>
      <input id="number" type="number" min="10" max="100"
      placeholder="07018005903"
    >
   <label for="dropdown">Choose an option:</label>
<select id="dropdown">
  <option value="student">Student</option>
  <option value="job">Full-Time Job</option>
</select>

<p>Would you recommend this course?</p>
<label>
  <input type="radio" name="recommend" value="yes"> Yes
</label>
<label>
  <input type="radio" name="recommend" value="no"> No
</label>

<p>What languages do you want to learn?</p>
<label>
  <input type="checkbox" value="python"> Python
</label>
<label>
  <input type="checkbox" value="javascript"> JavaScript
</label>
<label>
  <input type="checkbox" value="html-css"> HTML/CSS
</label>

<label for="comments">Any additional comments?</label>
<textarea id="comments" placeholder="Good..."></textarea>

<button id="submit" type="submit">
</button>
      
  </form>

</body>
</html>
  <body></body>
</html>